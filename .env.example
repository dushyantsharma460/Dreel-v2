# Optional — copy to .env and fill in values
# Without ELEVENLABS_API_KEY, edge-tts (free) is used automatically

ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Leave these two empty to get a random voice per reel (see config.py for
# the candidate lists). Set either one to pin every reel to that one voice.
ELEVENLABS_VOICE_ID=
EDGE_TTS_VOICE=

# Flask session secret key — generate your own, e.g. python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to "1" to enable Flask's debug reloader for local dev. Leave unset/"0"
# in production (Render sets neither — the Docker image defaults to off).
FLASK_DEBUG=

# On a host with an ephemeral filesystem (e.g. Render), point this at a
# mounted persistent disk so uploads/reels/datasets/model survive restarts.
# Leave empty for local dev — everything then stays under the project folder.
PERSIST_DIR=

# Optional — PostgreSQL mirror of the data/*.csv datasets, viewable in pgAdmin4.
# The app runs fine without this section set; database writes are best-effort
# and never block reel generation. To point at a DIFFERENT existing database,
# just change these values (or set DATABASE_URL directly) and restart.
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=dreel_ai
PG_USER=postgres
PG_PASSWORD=
# DATABASE_URL=postgresql+psycopg2://user:password@host:port/dbname

# Only used by docker-compose.yml (VM deployment, e.g. Oracle Cloud) to set
# the Postgres container's password. Not read by local `python app.py` dev —
# generate a real value before `docker compose up`.
# python -c "import secrets; print(secrets.token_hex(24))"
POSTGRES_PASSWORD=
